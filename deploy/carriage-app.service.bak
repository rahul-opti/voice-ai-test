[Unit]
Description=Carriage Services - Main Voice AI App
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=carriage
Group=carriage
WorkingDirectory=/opt/carriage-services
EnvironmentFile=/opt/carriage-services/.env
ExecStart=/opt/carriage-services/.venv/bin/uvicorn carriage_services.main:app \
    --host 0.0.0.0 \
    --port 8000 \
    --workers 1 \
    --log-level info
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=carriage-app

# Hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
